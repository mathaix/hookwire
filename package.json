{
  "name": "hookwire",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "db:migrate": "node packages/db/src/migrate.mjs migrate",
    "db:reset": "node packages/db/src/migrate.mjs reset",
    "test": "vitest run --coverage",
    "test:unit": "vitest run --coverage",
    "test:e2e": "playwright test",
    "proof:issue004:db": "node scripts/proof-issue-004-db.mjs",
    "proof:issue005:api": "node scripts/proof-issue-005-api.mjs",
    "proof:issue006:sessions": "node scripts/proof-issue-006-sessions.mjs",
    "proof:issue007:policies": "node scripts/proof-issue-007-policies.mjs",
    "proof:issue008:routes": "node scripts/proof-issue-008-routes.mjs",
    "proof:issue009:audit": "node scripts/proof-issue-009-audit.mjs",
    "web:build": "next build apps/web",
    "web:dev": "next dev apps/web",
    "web:e2e-server": "next build apps/web && next start apps/web --hostname 127.0.0.1 --port 3000",
    "web:lint": "node apps/web/lint.mjs",
    "web:start": "next start apps/web",
    "web:typecheck": "tsc --project apps/web/tsconfig.json --noEmit",
    "verify:docs": "node scripts/verify-docs.mjs"
  },
  "devDependencies": {
    "@playwright/test": "^1.56.0",
    "@vitest/coverage-v8": "^4.0.15",
    "pg": "^8.21.0",
    "vitest": "^4.0.15"
  },
  "dependencies": {
    "@types/node": "^25.9.3",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "next": "^16.2.9",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "typescript": "^6.0.3"
  }
}
